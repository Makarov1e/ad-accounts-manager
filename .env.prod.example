# Copy to .env on the server and fill in real secrets before `docker compose up`.

# --- Postgres (db service + DATABASE_URL) ---
POSTGRES_DB=adacc
POSTGRES_USER=adacc
POSTGRES_PASSWORD=change-me-strong-password

# --- Django ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=78.17.155.32,localhost
CSRF_TRUSTED_ORIGINS=http://78.17.155.32
# App is served over plain HTTP on the IP, so don't force an HTTPS redirect.
SECURE_SSL_REDIRECT=False

# --- Host port for the web (nginx) container ---
WEB_PORT=80
