# Copy to .env for local overrides. All values are optional in development.

# Secret key — generate a fresh one for production.
SECRET_KEY=django-insecure-dev-only-key-change-me-in-production

# Debug mode (True locally, False in production).
DEBUG=True

# Comma-separated hosts allowed to serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection string in production. Leave unset to use local SQLite.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Origins allowed to call the API from the browser (the Vue dev server / prod URL).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTPS origins trusted for CSRF in production, e.g. https://your-frontend.example.com
# CSRF_TRUSTED_ORIGINS=
